{
  "name": "invoices-microservice",
  "version": "0.1.0",
  "description": "Statex invoices service for proforma and final tax invoice issuance",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "test": "jest --runInBand",
    "verify:contracts": "node scripts/verify-invoice-contracts.js",
    "verify:runtime-readiness": "node scripts/verify-runtime-readiness.js",
    "verify:runtime-prereqs": "bash scripts/check-runtime-prereqs.sh",
    "verify:final-smoke-prereqs": "bash scripts/check-final-smoke-prereqs.sh",
    "verify:consumer-enable-prereqs": "ALLOW_CONSUMER_DISABLED=true bash scripts/check-final-smoke-prereqs.sh",
    "runtime:enable-orders-consumer": "bash scripts/enable-orders-consumer-for-final-smoke.sh"
  },
  "dependencies": {
    "@nestjs/axios": "^3.0.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "amqplib": "^0.10.3",
    "axios": "^1.6.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "pdfkit": "^0.19.1",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/amqplib": "^0.10.4",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.11.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node"
  }
}
